PORT=8080

# Auth (must match user-service)
AUTH_TOKEN_SECRET=change-me-use-same-value-as-user-service
AUTH_TOKEN_ISSUER=sharingbridge-user-service
AUTH_TOKEN_AUDIENCE=sharingbridge-clients

# Presets: use user_service when both services are deployed
PREFERENCES_BACKEND=user_service
USER_SERVICE_BASE_URL=http://localhost:8081
# PREFERENCES_BACKEND=local
# PREFERENCES_DB_PATH=./data/preferences.json

# AI orchestration (sharingbridge-ai-orchestration)
AI_ORCHESTRATION_BASE_URL=http://localhost:8091
AI_ORCHESTRATION_INTERNAL_API_KEY=
AI_ORCHESTRATION_TIMEOUT_MS=15000
AI_SUGGEST_VENDORS_ENABLED=true
AI_INSTRUCTION_PACK_ENABLED=true
