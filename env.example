PORT=8080

# Local: copy to .env — loaded automatically on `npm start` (dotenv).
# Render: set the same keys in the dashboard (no .env file on the host).

# PostgreSQL (required — same DATABASE_URL as user-service)
DATABASE_URL=postgresql://sharingbridge:sharingbridge@localhost:5432/sharingbridge
# Spatial extension schema (required) — must match configuration/schema-spatial-bootstrap.sql
GIS_SCHEMA=extensions
# Schema + indexes: https://github.com/sharingbridge/sharingbridge/blob/main/configuration/database.md

# Auth (must match user-service)
AUTH_TOKEN_SECRET=change-me-use-same-value-as-user-service
AUTH_TOKEN_ISSUER=sharingbridge-user-service
AUTH_TOKEN_AUDIENCE=sharingbridge-clients

# Donor presets (Postgres via user-service — required)
USER_SERVICE_BASE_URL=http://localhost:8081

# AI orchestration (sharingbridge-ai-orchestration)
AI_ORCHESTRATION_BASE_URL=http://localhost:8091
AI_ORCHESTRATION_INTERNAL_API_KEY=
# Per-route orchestration timeouts (integration-service → ai-orchestration)
AI_ORCHESTRATION_SUGGEST_VENDORS_TIMEOUT_MS=15000
AI_ORCHESTRATION_INSTRUCTION_PACK_TIMEOUT_MS=60000
# Retries on Render/AI 429 (plain-text "Too Many Requests"); 5 attempts, 8s–45s backoff
# AI_ORCHESTRATION_RETRY_MAX_ATTEMPTS=5
# AI_ORCHESTRATION_SUGGEST_VENDORS_RETRY_MAX_ATTEMPTS=5
# AI_ORCHESTRATION_INSTRUCTION_PACK_RETRY_MAX_ATTEMPTS=5
# AI_ORCHESTRATION_RETRY_BASE_DELAY_MS=8000
# AI_ORCHESTRATION_RETRY_MAX_DELAY_MS=45000
AI_SUGGEST_VENDORS_ENABLED=true
AI_INSTRUCTION_PACK_ENABLED=true
# Local dev only — production Render leaves this unset (strict: no mock AI responses).
AI_MOCK_FALLBACK_ENABLED=true

# Initiator neighbourhood list (see configuration/environment-variables.md)
# INITIATOR_NEIGHBOURHOOD_WINDOW_HOURS=2
# INITIATOR_NEIGHBOURHOOD_RADIUS_M=5000

# GPS → postal locality_key (IN:TN:PIN) via Nominatim reverse geocode
# NOMINATIM_USER_AGENT=SharingBridge-Integration-Service/1.0
# GEOCODER_PROVIDER=nominatim   # reserved — v1 implicit nominatim; see design/Location_Services_Vendor_Abstraction.md
# ORDER_INTENT_LIST_MAX_ROWS=100

# Connection-ready push/email webhook (sharingbridge-notification-service)
# CONNECTION_NOTIFY_WEBHOOK_URL=http://localhost:8093/internal/connection-ready
# CONNECTION_NOTIFY_WEBHOOK_SECRET=change-me-shared-with-notification-service

# Browser dashboard origin (NOT the API URL). Must match user-service exactly.
# Local .env: http://localhost:5173. Render: https://<your-static-site>.onrender.com (see configuration/backend-render.md).
WEB_CORS_ORIGINS=http://localhost:5173

# Logging: error | warn (default) | info | debug — warn = issues only at startup/request
LOG_LEVEL=warn
